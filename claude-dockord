#!/bin/bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR"

APP_NAME="claude-dockord"
export COMPOSE_PROJECT_NAME="$APP_NAME"

# shellcheck disable=SC1091
source "$SCRIPT_DIR/lib/ui.sh"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/lib/session.sh"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/lib/auth.sh"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/lib/open-terminal.sh"

RAM="16g"

append_source() {
    local value="${1:-}"

    [ -n "$value" ] || return 0

    if [ -n "${SOURCES:-}" ]; then
        SOURCES="${SOURCES}"$'\n'"- $value"
        return 0
    fi

    SOURCES="- $value"
}

mode_requires_auth() {
    case "${1:-}" in
        task|ralph|agents|auto) return 0 ;;
        *) return 1 ;;
    esac
}

print_connection_summary() {
    local project_path="${1:?project path is required}"
    local ssh_port="${2:?ssh port is required}"
    local mode="${3:?mode is required}"
    local connect_command
    local attach_command

    connect_command="$(ssh_command "$ssh_port")"
    attach_command="$(ssh_attach_command "$ssh_port")"

    echo ""
    divider
    echo ""
    ok "Container ready."
    echo ""
    echo -e "  ${B}Project:${N}   ${C}$project_path${N}"
    echo -e "  ${B}Mode:${N}      ${C}$mode${N}"
    echo -e "  ${B}SSH Port:${N}  ${C}$ssh_port${N}"
    echo ""
    echo -e "  ${B}Connect:${N}"
    echo "    $connect_command"
    echo ""
    echo -e "  ${B}Attach tmux:${N}"
    echo "    $attach_command"
    echo ""
    echo -e "  ${B}Useful:${N}"
    echo "    $APP_NAME attach"
    echo "    $APP_NAME monitor"
    echo "    $APP_NAME logs"
    echo ""
}

maybe_authenticate_idle_session() {
    if container_has_claude_auth; then
        ok "Claude Max credentials already present"
        return 0
    fi

    echo ""
    if is_yes "$(read_with_default "Authenticate with Claude Max in your browser now? [Y/n]: " "Y")"; then
        run_claude_subscription_auth
        ok "Claude Max auth completed"
    else
        warn "Skipping Claude Max auth for now. SSH access still works; prompts that use Claude will require login later."
    fi
}

maybe_open_terminal() {
    local ssh_port="${1:?ssh port is required}"
    local open_terminal="${2:?open terminal flag is required}"
    local attach_command

    if [ "$open_terminal" != "true" ]; then
        return 0
    fi

    attach_command="$(ssh_attach_command "$ssh_port")"

    if open_in_new_terminal "$attach_command"; then
        ok "Opened a new terminal window attached to the container."
        return 0
    fi

    warn "Automatic terminal opening is not available on this host."
}

ensure_auth_if_needed() {
    local mode="${1:?mode is required}"

    if ! mode_requires_auth "$mode"; then
        return 0
    fi

    if container_has_claude_auth; then
        ok "Claude Max credentials already present"
        return 0
    fi

    info "Claude Max login is required before the initial task can start."
    run_claude_subscription_auth
    ok "Claude Max auth completed"
}

ensure_ralph_if_needed() {
    local mode="${1:?mode is required}"

    if [ "$mode" != "ralph" ]; then
        return 0
    fi

    if ensure_ralph_plugin; then
        ok "Ralph plugin is installed"
        return 0
    fi

    warn "Could not verify Ralph plugin installation automatically."
}

interactive_collect_run_options() {
    local prompt_input
    local choice

    MODE=""
    TASK=""
    SOURCES=""
    OPEN_TERMINAL="${OPEN_TERMINAL:-ask}"
    SHOW_RC_HINT="${SHOW_RC_HINT:-0}"

    banner
    echo -e "  ${B}Project:${N} $PROJECT_PATH"
    echo ""
    divider
    echo ""

    prompt_input="$(read_with_default "Initial prompt/spec [leave blank to boot idle]: " "")"
    TASK="$prompt_input"

    if [ -n "$TASK" ]; then
        local source_input
        source_input="$(read_with_default "Supporting source, path, URL, or note [optional]: " "")"
        append_source "$source_input"

        echo ""
        echo -e "  ${B}How should the initial work run?${N}"
        echo ""
        echo "    1) Ralph loop (default)"
        echo "    2) Agent team kickoff"
        echo "    3) Fire-and-forget"
        echo "    4) Auto-restart on rate limits"
        echo ""
        choice="$(read_with_default "Choice [1]: " "1")"

        case "$choice" in
            1) MODE="ralph" ;;
            2) MODE="agents" ;;
            3) MODE="task" ;;
            4) MODE="auto" ;;
            *) fail "Invalid choice: $choice"; exit 1 ;;
        esac

        if [ "$MODE" = "ralph" ]; then
            MAX_ITER="$(read_with_default "Max Ralph iterations [30]: " "30")"
        fi
    else
        MODE="idle"
    fi

    echo ""
    RAM="$(read_with_default "RAM allocation [${RAM}]: " "$RAM")"

    if [ "$OPEN_TERMINAL" = "ask" ] && terminal_supports_auto_open; then
        echo ""
        if is_yes "$(read_with_default "Open a new terminal and attach now? [Y/n]: " "Y")"; then
            OPEN_TERMINAL="true"
        else
            OPEN_TERMINAL="false"
        fi
    fi
}

parse_run_flags() {
    MODE=""
    TASK=""
    SOURCES=""
    MAX_ITER=30
    REQUESTED_SSH_PORT=""
    OPEN_TERMINAL="ask"
    SHOW_RC_HINT=0

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --ram)
                RAM="$2"
                shift 2
                ;;
            --task)
                MODE="task"
                TASK="$2"
                shift 2
                ;;
            --ralph)
                MODE="ralph"
                TASK="$2"
                shift 2
                ;;
            --ralph-iter)
                MAX_ITER="$2"
                shift 2
                ;;
            --agents)
                MODE="agents"
                TASK="$2"
                shift 2
                ;;
            --auto)
                MODE="auto"
                TASK="$2"
                shift 2
                ;;
            --source)
                append_source "$2"
                shift 2
                ;;
            --ssh-port)
                REQUESTED_SSH_PORT="$2"
                shift 2
                ;;
            --no-open)
                OPEN_TERMINAL="false"
                shift
                ;;
            --rc)
                SHOW_RC_HINT=1
                shift
                ;;
            *)
                fail "Unknown option: $1"
                exit 1
                ;;
        esac
    done
}

start_or_refresh_container() {
    local project_path="${1:?project path is required}"
    local mode="${2:?mode is required}"
    local initial_request="${3:-}"
    local ssh_port="${4:?ssh port is required}"

    banner
    step "1/4" "Preparing local SSH access..."
    ensure_state_dir
    ensure_ssh_key
    ok "SSH key ready at $SSH_KEY_PATH"
    echo ""

    step "2/4" "Building and starting the persistent container..."
    export_compose_environment "$project_path" "$RAM" "$ssh_port"
    docker_compose_up
    wait_for_container
    wait_for_ssh "$ssh_port"
    ok "Container is running on localhost:$ssh_port"
    echo ""

    step "3/4" "Checking Claude prerequisites..."
    ensure_auth_if_needed "$mode"
    ensure_ralph_if_needed "$mode"
    echo ""

    step "4/4" "Launching the dockord tmux session..."
    launch_mode_session "$mode" "$initial_request" "$MAX_ITER"
    ok "tmux session '$SESSION_NAME' is ready"
    echo ""

    save_session_state "$project_path" "$ssh_port" "$RAM" "$mode"
}

cmd_setup() {
    local ssh_port

    PROJECT_PATH="$SCRIPT_DIR"
    MODE="idle"
    MAX_ITER=30

    ensure_host_dependencies
    ssh_port="$(pick_ssh_port "")"
    start_or_refresh_container "$PROJECT_PATH" "$MODE" "" "$ssh_port"

    step "5/6" "Authenticating Claude..."
    if container_has_claude_auth; then
        ok "Claude Max credentials already present"
    else
        run_claude_subscription_auth
        ok "Claude Max auth completed"
    fi
    echo ""

    step "6/6" "Installing Ralph plugin..."
    if ensure_ralph_plugin; then
        ok "Ralph plugin is installed"
    else
        warn "Could not verify Ralph plugin installation automatically."
    fi
    echo ""

    print_connection_summary "$PROJECT_PATH" "$ssh_port" "$MODE"
}

cmd_run() {
    local raw_project_path="${1:-}"
    local interactive_mode="false"
    local ssh_port
    local initial_request=""

    if [ -z "$raw_project_path" ]; then
        banner
        raw_project_path="$(read_with_default "Project path: " "")"
        [ -n "$raw_project_path" ] || { fail "No project path provided."; exit 1; }
    else
        shift || true
    fi

    PROJECT_PATH="$(resolve_project_path "$raw_project_path")"
    parse_run_flags "$@"

    if [ -z "$MODE" ]; then
        interactive_mode="true"
        interactive_collect_run_options
    fi

    if [ -z "$MODE" ]; then
        MODE="idle"
    fi

    ensure_host_dependencies
    ssh_port="$(pick_ssh_port "$REQUESTED_SSH_PORT")"

    if [ -n "$TASK" ]; then
        initial_request="$(build_initial_prompt "$TASK" "$SOURCES")"
    fi

    start_or_refresh_container "$PROJECT_PATH" "$MODE" "$initial_request" "$ssh_port"

    if [ "$interactive_mode" = "true" ] && [ "$MODE" = "idle" ]; then
        maybe_authenticate_idle_session
    fi

    if [ "$SHOW_RC_HINT" -eq 1 ]; then
        info "After connecting, run /rc inside the container to enable Remote Control."
    fi

    print_connection_summary "$PROJECT_PATH" "$ssh_port" "$MODE"

    if [ "$interactive_mode" = "true" ]; then
        maybe_open_terminal "$ssh_port" "$OPEN_TERMINAL"
    fi
}

cmd_monitor() {
    docker_daemon_available || {
        fail "Cannot connect to the Docker daemon."
        exit 1
    }

    if ! container_is_running; then
        fail "Container not running. Start a session first."
        exit 1
    fi

    docker exec -it --user claude "$CONTAINER_NAME" ccusage blocks --live
}

cmd_logs() {
    docker_daemon_available || {
        fail "Cannot connect to the Docker daemon."
        exit 1
    }

    docker run --rm -v "${COMPOSE_PROJECT_NAME}_agent-logs:/logs" alpine \
        sh -c 'ls -la /logs/ 2>/dev/null || echo "No logs yet."'
}

cmd_log() {
    local safe_name

    docker_daemon_available || {
        fail "Cannot connect to the Docker daemon."
        exit 1
    }

    safe_name="$(sanitize_log_filename "${1:?Usage: claude-dockord log <filename>}")" || {
        fail "Log filename must be a single basename."
        exit 1
    }

    docker run --rm -v "${COMPOSE_PROJECT_NAME}_agent-logs:/logs" alpine cat "/logs/$safe_name"
}

cmd_export_logs() {
    docker_daemon_available || {
        fail "Cannot connect to the Docker daemon."
        exit 1
    }

    mkdir -p ./agent-logs-export
    docker run --rm \
        -v "${COMPOSE_PROJECT_NAME}_agent-logs:/src" \
        -v "$(pwd)/agent-logs-export:/dst" \
        alpine cp -r /src/. /dst/
    ok "Logs exported to ./agent-logs-export/"
}

cmd_status() {
    docker_daemon_available || {
        fail "Cannot connect to the Docker daemon."
        exit 1
    }

    docker compose ps

    if load_session_state; then
        echo ""
        echo "SSH:"
        echo "  $(ssh_command "$SSH_PORT")"
    fi
}

cmd_attach() {
    docker_daemon_available || {
        fail "Cannot connect to the Docker daemon."
        exit 1
    }

    if ! container_is_running; then
        fail "Container not running. Start a session first."
        exit 1
    fi

    docker exec -it --user claude --workdir /workspace -e HOME=/home/claude "$CONTAINER_NAME" \
        bash -lc "tmux attach -t '$SESSION_NAME' || exec zsh -l"
}

cmd_teardown() {
    docker_daemon_available || {
        fail "Cannot connect to the Docker daemon."
        exit 1
    }

    docker compose down
    rm -f "$SESSION_STATE_PATH"
}

cmd_nuke() {
    docker_daemon_available || {
        fail "Cannot connect to the Docker daemon."
        exit 1
    }

    docker compose down -v --rmi local
    rm -f "$SESSION_STATE_PATH"
}

main() {
    case "${1:-}" in
        setup)
            shift
            cmd_setup "$@"
            ;;
        run)
            shift
            cmd_run "$@"
            ;;
        monitor)
            cmd_monitor
            ;;
        logs)
            cmd_logs
            ;;
        log)
            shift
            cmd_log "$@"
            ;;
        export-logs)
            cmd_export_logs
            ;;
        status)
            cmd_status
            ;;
        attach)
            cmd_attach
            ;;
        teardown)
            cmd_teardown
            ;;
        nuke)
            cmd_nuke
            ;;
        -h|--help|help|"")
            usage "$APP_NAME"
            ;;
        *)
            fail "Unknown command: $1"
            usage "$APP_NAME"
            exit 1
            ;;
    esac
}

if [ "${BASH_SOURCE[0]}" = "$0" ]; then
    main "$@"
fi
